{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-window",
  "description": "Capability for the main host webview",
  "webviews": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "dialog:allow-open",
    "shell:default",
    "mcp-bridge:default",
    "allow-greet",
    "allow-get-api-url",
    "allow-check-backend-status",
    "allow-get-system-info",
    "allow-plugin-list",
    "allow-plugin-mount-view",
    "allow-plugin-update-view-bounds",
    "allow-plugin-unmount-view",
    "allow-plugin-call",
    "allow-plugin-api-request",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "args": true,
          "cmd": "",
          "name": "binaries/slab-server",
          "sidecar": true
        }
      ]
    }
  ]
}
