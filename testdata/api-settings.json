{
  "$schema": "https://slab.reorgix.com/manifests/v1/settings-document.schema.json",
  "schema_version": 2,
  "general": {
    "language": "auto"
  },
  "database": {
    "url": "sqlite://slab.db?mode=rwc"
  },
  "logging": {
    "level": "info",
    "json": false
  },
  "tools": {
    "ffmpeg": {
      "enabled": true,
      "auto_download": true,
      "source": {}
    }
  },
  "runtime": {
    "mode": "managed_children",
    "transport": "ipc",
    "sessions": {},
    "logging": {},
    "capacity": {
      "queue": 64,
      "concurrent_requests": 4
    },
    "endpoint": {
      "http": {},
      "ipc": {}
    },
    "ggml": {
      "source": {},
      "logging": {},
      "capacity": {},
      "endpoint": {
        "http": {},
        "ipc": {}
      },
      "backends": {
        "llama": {
          "enabled": false,
          "flash_attn": true,
          "source": {},
          "logging": {},
          "capacity": {},
          "endpoint": {
            "http": {},
            "ipc": {}
          }
        },
        "whisper": {
          "enabled": false,
          "flash_attn": true,
          "source": {},
          "logging": {},
          "capacity": {},
          "endpoint": {
            "http": {},
            "ipc": {}
          }
        },
        "diffusion": {
          "enabled": false,
          "flash_attn": true,
          "source": {},
          "logging": {},
          "capacity": {
            "concurrent_requests": 1
          },
          "endpoint": {
            "http": {},
            "ipc": {}
          }
        }
      }
    },
    "candle": {
      "enabled": false,
      "source": {},
      "logging": {},
      "capacity": {},
      "endpoint": {
        "http": {},
        "ipc": {}
      }
    },
    "onnx": {
      "enabled": false,
      "source": {},
      "logging": {},
      "capacity": {},
      "endpoint": {
        "http": {},
        "ipc": {}
      }
    }
  },
  "providers": {
    "registry": []
  },
  "models": {
    "download_source": "auto",
    "auto_unload": {
      "enabled": false,
      "idle_minutes": 10,
      "min_free_system_memory_bytes": 1073741824,
      "min_free_gpu_memory_bytes": 536870912,
      "max_pressure_evictions_per_load": 3
    }
  },
  "plugin": {
    "install_dir": "./testdata\\plugins"
  },
  "server": {
    "address": "127.0.0.1:3000",
    "logging": {},
    "cors": {},
    "admin": {},
    "swagger": {
      "enabled": true
    },
    "cloud_http_trace": false
  }
}
