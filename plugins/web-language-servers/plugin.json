{
  "manifestVersion": 1,
  "id": "web-language-servers",
  "name": "Web Language Servers",
  "version": "0.1.0",
  "compatibility": {
    "slab": ">=0.1.0",
    "pluginApi": "^1.0.0"
  },
  "runtime": {
    "ui": {
      "entry": "ui/index.html"
    }
  },
  "permissions": {
    "network": {
      "mode": "blocked",
      "allowHosts": []
    },
    "lsp": [
      "languageServer:declare"
    ]
  },
  "contributes": {
    "languageServers": [
      {
        "id": "web-language-servers.typescript",
        "languages": [
          "typescript",
          "typescriptreact",
          "javascript",
          "javascriptreact"
        ],
        "transport": {
          "type": "nodePackage",
          "package": "typescript-language-server",
          "args": [
            "--stdio"
          ]
        }
      },
      {
        "id": "web-language-servers.json",
        "languages": [
          "json",
          "jsonc"
        ],
        "transport": {
          "type": "nodePackage",
          "package": "vscode-langservers-extracted",
          "command": "vscode-json-language-server",
          "args": [
            "--stdio"
          ]
        }
      },
      {
        "id": "web-language-servers.css",
        "languages": [
          "css",
          "less",
          "scss"
        ],
        "transport": {
          "type": "nodePackage",
          "package": "vscode-langservers-extracted",
          "command": "vscode-css-language-server",
          "args": [
            "--stdio"
          ]
        }
      },
      {
        "id": "web-language-servers.html",
        "languages": [
          "html"
        ],
        "transport": {
          "type": "nodePackage",
          "package": "vscode-langservers-extracted",
          "command": "vscode-html-language-server",
          "args": [
            "--stdio"
          ]
        }
      }
    ]
  }
}
