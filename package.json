{
  "name": "slab-workspace",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.3.11",
  "engines": {
    "node": ">=24",
    "bun": ">=1.3.11"
  },
  "type": "module",
  "scripts": {
    "dev:app": "cargo make dev",
    "check:frontend": "bun run lint && bun run --cwd packages/api build && bun run --cwd packages/slab-plugin-sdk build && bun run --cwd packages/slab-plugin-ui build && bun run --cwd packages/slab-desktop build",
    "check:rust": "cargo check --workspace",
    "check": "bun run check:frontend && bun run check:rust",
    "build:desktop": "bun run --cwd packages/slab-desktop build",
    "build:app": "cargo build --release -p slab-server --features gpu-telemetry && cargo build --release -p slab-runtime && cargo build --release -p slab-js-runtime && cargo build --release -p slab-python-runtime && bun run gen:plugin-packs && bun run --cwd bin/slab-app build",
    "build:windows-installer": "cargo make build-windows-full-installer",
    "dev:desktop": "bun run --cwd packages/slab-desktop dev",
    "gen:api": "bun ./scripts/gen/generate-openapi.ts",
    "gen:schemas": "cargo run -p slab-model-pack --bin generate_manifest_schema && cargo run -p slab-config --bin generate_settings_document_schema",
    "gen:plugin-packs": "bun ./scripts/plugins/generate-plugin-packs.ts",
    "gen:model-packs": "bun ./scripts/models/pack-models.ts",
    "color:oklch": "bun ./scripts/design/figma-color-to-oklch.ts",
    "lint": "oxlint packages/api packages/slab-desktop packages/slab-components packages/slab-i18n packages/slab-plugin-sdk packages/slab-plugin-ui packages/vitest-rust-reporter plugins/video-subtitle-translator/src scripts",
    "lint:fix": "oxlint --fix packages/api packages/slab-desktop packages/slab-components packages/slab-i18n packages/slab-plugin-sdk packages/slab-plugin-ui packages/vitest-rust-reporter plugins/video-subtitle-translator/src scripts",
    "test": "bun run test:frontend && bun run test:server && bun run test:rust",
    "test:frontend": "vitest run --project api --project plugin-sdk --project desktop --project desktop-browser --project components-browser",
    "test:rust": "vitest run --project rust",
    "test:sandbox": "cargo test -p slab-sandboxing --test smoke -- --nocapture",
    "test:browser": "vitest run --project desktop-browser --project components-browser",
    "test:components": "vitest run --project components-browser",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:desktop": "vitest run --project desktop",
    "test:desktop:browser": "vitest run --project desktop-browser",
    "test:server": "vitest run --project slab-server-tests",
    "test:update-screenshots": "vitest run --project desktop-browser --project components-browser -u",
    "docs:dev": "bun run gen:schemas && vitepress dev docs",
    "docs:build": "bun run gen:schemas && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepare": "husky"
  },
  "workspaces": [
    "packages/api",
    "packages/slab-desktop",
    "packages/slab-plugin-sdk",
    "packages/slab-plugin-ui",
    "packages/slab-components",
    "packages/slab-i18n",
    "packages/vitest-rust-reporter",
    "plugins/*",
    "bin/slab-app",
    "models",
    "docs"
  ],
