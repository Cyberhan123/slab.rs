{
  "name": "slab-workspace",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.3.11",
  "engines": {
    "node": ">=24",
    "bun": ">=1.3.11"
  },
  "type": "module",
  "scripts": {
    "api": "bunx openapi-typescript http://127.0.0.1:3000/api-docs/openapi.json -o packages/api/src/v1.d.ts",
    "build:desktop": "bun run --filter @slab/desktop build",
    "build:plugins": "bun run build:plugin-packs",
    "build:plugin-packs": "bun run plugins/scripts/generate-plugin-packs.ts",
    "dev:desktop": "bun run --filter @slab/desktop dev",
    "api:desktop": "bun run api",
    "lint": "oxlint packages/api packages/slab-desktop packages/slab-components packages/slab-i18n packages/slab-plugin-sdk packages/slab-plugin-ui packages/vitest-rust-reporter plugins/video-subtitle-translator/src models/scripts",
    "lint:fix": "oxlint --fix packages/api packages/slab-desktop packages/slab-components packages/slab-i18n packages/slab-plugin-sdk packages/slab-plugin-ui packages/vitest-rust-reporter plugins/video-subtitle-translator/src models/scripts",
    "test": "vitest",
    "test:browser": "vitest run --project desktop-browser --project components-browser",
    "test:components": "vitest run --project components-browser",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:desktop": "vitest run --project desktop",
    "test:desktop:browser": "vitest run --project desktop-browser",
    "test:server": "vitest run --project slab-server-tests",
    "test:update-screenshots": "vitest run --project desktop-browser --project components-browser -u",
    "docs:schemas": "cargo run -p slab-model-pack --bin generate_manifest_schema && cargo run -p slab-types --bin generate_settings_document_schema",
    "docs:dev": "bun run docs:schemas && vitepress dev docs",
    "docs:build": "bun run docs:schemas && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "models:pack": "bun run --filter @slab/models pack",
    "prepare": "husky"
  },
  "workspaces": [
    "packages/api",
    "packages/slab-desktop",
    "packages/slab-plugin-sdk",
    "packages/slab-plugin-ui",
    "packages/slab-components",
    "packages/slab-i18n",
    "packages/vitest-rust-reporter",
    "plugins/*",
    "bin/slab-app",
    "models",
    "docs"
  ],
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser": "^4.1.4",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.60.0",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.3",
    "vitepress": "^2.0.0-alpha.17",
    "vitest": "^4.1.4",
    "vitest-browser-react": "^2.2.0"
  },
  "license": "AGPL-3.0-only"
}
