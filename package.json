{
  "name": "slab-workspace",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "build:desktop": "bun run --filter @slab/desktop build",
    "dev:desktop": "bun run --filter @slab/desktop dev",
    "api:desktop": "bun run --filter @slab/desktop api"
  },
  "workspaces": [
    "packages/slab-desktop",
    "packages/slab-components",
    "packages/slab-i18n",
    "bin/slab-app"
  ],
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2"
  }
}
