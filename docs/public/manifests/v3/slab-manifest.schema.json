{
  "$defs": {
    "ArtifactFormat": {
      "enum": [
        "gguf",
        "ggml",
        "safetensors",
        "onnx",
        "ckpt"
      ],
      "type": "string"
    },
    "Capability": {
      "enum": [
        "text_generation",
        "audio_transcription",
        "image_generation",
        "image_embedding",
        "chat_generation",
        "audio_vad",
        "video_generation"
      ],
      "type": "string"
    },
    "CloudCredentials": {
      "additionalProperties": false,
      "properties": {
        "secret_ref": {
          "type": "string"
        }
      },
      "required": [
        "secret_ref"
      ],
      "type": "object"
    },
    "CloudModelTarget": {
      "additionalProperties": false,
      "properties": {
        "credentials": {
          "anyOf": [
            {
              "$ref": "#/$defs/CloudCredentials"
            },
            {
              "type": "null"
            }
          ]
        },
        "preferred_api_base": {
          "type": [
            "string",
            "null"
          ]
        },
        "provider_id": {
          "type": "string"
        },
        "remote_model_id": {
          "type": "string"
        }
      },
      "required": [
        "provider_id",
        "remote_model_id"
      ],
      "type": "object"
    },
    "ConfigEntryRef": {
      "additionalProperties": false,
      "properties": {
        "$ref": {
          "$ref": "#/$defs/ConfigRef"
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "label",
        "$ref"
      ],
      "type": "object"
    },
    "ConfigRef": {
      "type": "string"
    },
    "EngineTarget": {
      "properties": {
        "format": {
          "$ref": "#/$defs/ArtifactFormat"
        },
        "id": {
          "$ref": "#/$defs/RuntimeBackendId"
        }
      },
      "required": [
        "id",
        "format"
      ],
      "type": "object"
    },
    "ModelFamily": {
      "enum": [
        "llama",
        "whisper",
        "diffusion",
        "onnx"
      ],
      "type": "string"
    },
    "PackDeployment": {
      "enum": [
        "local",
        "cloud"
      ],
      "type": "string"
    },
    "PackPricing": {
      "properties": {
        "input": {
          "format": "double",
          "type": "number"
        },
        "output": {
          "format": "double",
          "type": "number"
        }
      },
      "required": [
        "input",
        "output"
      ],
      "type": "object"
    },
    "PackSourceCandidate": {
      "oneOf": [
        {
          "properties": {
            "kind": {
              "const": "local_path",
              "type": "string"
            },
            "path": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "path"
          ],
          "type": "object"
        },
        {
          "properties": {
            "files": {
              "items": {
                "$ref": "#/$defs/PackSourceFile"
              },
              "type": "array"
            },
            "kind": {
              "const": "local_files",
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
        },
        {
          "properties": {
            "files": {
              "items": {
                "$ref": "#/$defs/PackSourceFile"
              },
              "type": "array"
            },
            "kind": {
              "const": "hugging_face",
              "type": "string"
            },
            "repo_id": {
              "type": "string"
            },
            "revision": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "required": [
            "kind",
            "repo_id"
          ],
          "type": "object"
        },
        {
          "properties": {
            "files": {
              "items": {
                "$ref": "#/$defs/PackSourceFile"
              },
              "type": "array"
            },
            "kind": {
              "const": "model_scope",
              "type": "string"
            },
            "repo_id": {
              "type": "string"
            },
            "revision": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "required": [
            "kind",
            "repo_id"
          ],
          "type": "object"
        }
      ],
      "properties": {
        "priority": {
          "format": "int32",
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "PackSourceFile": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "type": "string"
        },
        "label": {
          "type": [
            "string",
            "null"
          ]
        },
        "path": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "path"
      ],
      "type": "object"
    },
    "PresetEntryRef": {
      "additionalProperties": false,
      "properties": {
        "$ref": {
          "$ref": "#/$defs/ConfigRef"
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "label",
        "$ref"
      ],
      "type": "object"
    },
    "ResourceFootprint": {
      "properties": {
        "ram_mb": {
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "vram_mb": {
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "RuntimeBackendId": {
      "description": "Canonical backend identifiers exposed on the runtime boundary today.",
      "enum": [
        "ggml_llama",
        "ggml_whisper",
        "ggml_diffusion",
        "candle_llama",
        "candle_whisper",
        "candle_diffusion",
        "onnx"
      ],
      "type": "string"
    }
  },
  "$id": "https://slab.reorgix.com/manifests/v3/slab-manifest.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Schema for the manifest.json file stored at the root of a .slab model pack.",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "adapters": {
      "items": {
        "$ref": "#/$defs/ConfigEntryRef"
      },
      "type": "array"
    },
    "capabilities": {
      "default": [],
      "items": {
        "$ref": "#/$defs/Capability"
      },
      "type": "array"
    },
    "cloud": {
      "anyOf": [
        {
          "$ref": "#/$defs/CloudModelTarget"
        },
        {
          "type": "null"
        }
      ]
    },
    "components": {
      "items": {
        "$ref": "#/$defs/ConfigEntryRef"
      },
      "type": "array"
    },
    "context_window": {
      "format": "uint32",
      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    },
    "default_preset": {
      "type": [
        "string",
        "null"
      ]
    },
    "deployment": {
      "$ref": "#/$defs/PackDeployment"
    },
    "engines": {
      "items": {
        "$ref": "#/$defs/EngineTarget"
      },
      "type": "array"
    },
    "family": {
      "$ref": "#/$defs/ModelFamily"
    },
    "footprint": {
      "$ref": "#/$defs/ResourceFootprint",
      "default": {}
    },
    "id": {
      "type": "string"
    },
    "label": {
      "type": "string"
    },
    "metadata": {
      "additionalProperties": {
        "type": "string"
      },
      "type": "object"
    },
    "presets": {
      "items": {
        "$ref": "#/$defs/PresetEntryRef"
      },
      "type": "array"
    },
    "pricing": {
      "anyOf": [
        {
          "$ref": "#/$defs/PackPricing"
        },
        {
          "type": "null"
        }
      ]
    },
    "schema_version": {
      "format": "uint32",
      "minimum": 0,
      "type": "integer"
    },
    "sources": {
      "items": {
        "$ref": "#/$defs/PackSourceCandidate"
      },
      "type": "array"
    },
    "variants": {
      "items": {
        "$ref": "#/$defs/ConfigEntryRef"
      },
      "type": "array"
    }
  },
  "required": [
    "schema_version",
    "deployment",
    "id",
    "label",
    "family"
  ],
  "title": "slab.rs Model Pack Manifest",
  "type": "object"
}
