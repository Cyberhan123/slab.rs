{
  "$defs": {
    "Capability": {
      "enum": [
        "text_generation",
        "audio_transcription",
        "image_generation",
        "image_embedding",
        "chat_generation",
        "audio_vad",
        "video_generation"
      ],
      "type": "string"
    },
    "ConfigEntryRef": {
      "properties": {
        "$config": {
          "$ref": "#/$defs/ConfigRef"
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "label",
        "$config"
      ],
      "type": "object"
    },
    "ConfigRef": {
      "type": "string"
    },
    "DriverHints": {
      "properties": {
        "avoid_drivers": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "prefer_drivers": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "require_streaming": {
          "default": false,
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "ModelFamily": {
      "enum": [
        "llama",
        "whisper",
        "diffusion",
        "onnx"
      ],
      "type": "string"
    },
    "PackModelStatus": {
      "enum": [
        "ready",
        "not_downloaded",
        "downloading",
        "error"
      ],
      "type": "string"
    },
    "PackPricing": {
      "properties": {
        "input": {
          "format": "double",
          "type": "number"
        },
        "output": {
          "format": "double",
          "type": "number"
        }
      },
      "required": [
        "input",
        "output"
      ],
      "type": "object"
    },
    "PackRuntimePresets": {
      "properties": {
        "max_tokens": {
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "min_p": {
          "format": "float",
          "type": [
            "number",
            "null"
          ]
        },
        "presence_penalty": {
          "format": "float",
          "type": [
            "number",
            "null"
          ]
        },
        "repetition_penalty": {
          "format": "float",
          "type": [
            "number",
            "null"
          ]
        },
        "temperature": {
          "format": "float",
          "type": [
            "number",
            "null"
          ]
        },
        "top_k": {
          "format": "int32",
          "type": [
            "integer",
            "null"
          ]
        },
        "top_p": {
          "format": "float",
          "type": [
            "number",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "PackSourceCandidate": {
      "oneOf": [
        {
          "properties": {
            "kind": {
              "const": "local_path",
              "type": "string"
            },
            "path": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "path"
          ],
          "type": "object"
        },
        {
          "properties": {
            "files": {
              "items": {
                "$ref": "#/$defs/PackSourceFile"
              },
              "type": "array"
            },
            "kind": {
              "const": "local_files",
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
        },
        {
          "properties": {
            "files": {
              "items": {
                "$ref": "#/$defs/PackSourceFile"
              },
              "type": "array"
            },
            "kind": {
              "const": "hugging_face",
              "type": "string"
            },
            "repo_id": {
              "type": "string"
            },
            "revision": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "required": [
            "kind",
            "repo_id"
          ],
          "type": "object"
        },
        {
          "properties": {
            "files": {
              "items": {
                "$ref": "#/$defs/PackSourceFile"
              },
              "type": "array"
            },
            "kind": {
              "const": "model_scope",
              "type": "string"
            },
            "repo_id": {
              "type": "string"
            },
            "revision": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "required": [
            "kind",
            "repo_id"
          ],
          "type": "object"
        },
        {
          "properties": {
            "kind": {
              "const": "cloud",
              "type": "string"
            },
            "provider_id": {
              "type": "string"
            },
            "remote_model_id": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "provider_id",
            "remote_model_id"
          ],
          "type": "object"
        }
      ],
      "properties": {
        "priority": {
          "format": "int32",
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "PackSourceFile": {
      "properties": {
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "type": "string"
        },
        "label": {
          "type": [
            "string",
            "null"
          ]
        },
        "path": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "path"
      ],
      "type": "object"
    },
    "PresetEntryRef": {
      "properties": {
        "$config": {
          "$ref": "#/$defs/ConfigRef"
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "variant_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "id",
        "label",
        "$config"
      ],
      "type": "object"
    },
    "ResourceFootprint": {
      "properties": {
        "ram_mb": {
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "vram_mb": {
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "type": "object"
    }
  },
  "$id": "https://slab.reorgix.com/manifests/v1/slab-manifest.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Schema for the manifest.json file stored at the root of a .slab model pack.",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "adapters": {
      "items": {
        "$ref": "#/$defs/ConfigEntryRef"
      },
      "type": "array"
    },
    "backend_hints": {
      "$ref": "#/$defs/DriverHints",
      "default": {
        "avoid_drivers": [],
        "prefer_drivers": [],
        "require_streaming": false
      }
    },
    "capabilities": {
      "default": [],
      "items": {
        "$ref": "#/$defs/Capability"
      },
      "type": "array"
    },
    "components": {
      "items": {
        "$ref": "#/$defs/ConfigEntryRef"
      },
      "type": "array"
    },
    "context_window": {
      "format": "uint32",
      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    },
    "default_preset": {
      "type": [
        "string",
        "null"
      ]
    },
    "family": {
      "$ref": "#/$defs/ModelFamily"
    },
    "footprint": {
      "$ref": "#/$defs/ResourceFootprint",
      "default": {}
    },
    "id": {
      "type": "string"
    },
    "label": {
      "type": "string"
    },
    "metadata": {
      "additionalProperties": {
        "type": "string"
      },
      "type": "object"
    },
    "presets": {
      "items": {
        "$ref": "#/$defs/PresetEntryRef"
      },
      "type": "array"
    },
    "pricing": {
      "anyOf": [
        {
          "$ref": "#/$defs/PackPricing"
        },
        {
          "type": "null"
        }
      ]
    },
    "runtime_presets": {
      "anyOf": [
        {
          "$ref": "#/$defs/PackRuntimePresets"
        },
        {
          "type": "null"
        }
      ]
    },
    "sources": {
      "items": {
        "$ref": "#/$defs/PackSourceCandidate"
      },
      "type": "array"
    },
    "status": {
      "anyOf": [
        {
          "$ref": "#/$defs/PackModelStatus"
        },
        {
          "type": "null"
        }
      ]
    },
    "variants": {
      "items": {
        "$ref": "#/$defs/ConfigEntryRef"
      },
      "type": "array"
    },
    "version": {
      "format": "uint32",
      "minimum": 0,
      "type": "integer"
    }
  },
  "required": [
    "version",
    "id",
    "label",
    "family"
  ],
  "title": "slab.rs Model Pack Manifest",
  "type": "object"
}
