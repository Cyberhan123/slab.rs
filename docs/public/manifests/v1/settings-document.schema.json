{
  "$defs": {
    "AdminConfig": {
      "description": "Server admin settings.",
      "properties": {
        "token": {
          "description": "Optional bearer token required for admin APIs.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "AgentHookScriptConfig": {
      "description": "Explicit local script registered for agent lifecycle hook execution.",
      "properties": {
        "enabled": {
          "default": true,
          "type": "boolean"
        },
        "entry": {
          "type": "string"
        },
        "events": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "export_name": {
          "default": "run",
          "type": "string"
        },
        "language": {
          "$ref": "#/$defs/AgentHookScriptLanguage"
        },
        "name": {
          "type": "string"
        },
        "root_dir": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "language",
        "root_dir",
        "entry"
      ],
      "type": "object"
    },
    "AgentHookScriptLanguage": {
      "enum": [
        "javascript",
        "python"
      ],
      "type": "string"
    },
    "AgentHooksConfig": {
      "description": "Agent lifecycle hook settings.",
      "properties": {
        "enabled": {
          "default": false,
          "type": "boolean"
        },
        "scripts": {
          "items": {
            "$ref": "#/$defs/AgentHookScriptConfig"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "AgentMcpConfig": {
      "description": "Agent MCP tool integration settings.",
      "properties": {
        "enabled": {
          "default": false,
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "AgentMemoriesConfig": {
      "description": "Agent memory pipeline settings.",
      "properties": {
        "enabled": {
          "default": false,
          "type": "boolean"
        },
        "extension_retention_days": {
          "default": 30,
          "format": "int64",
          "type": "integer"
        },
        "max_unused_days": {
          "default": 180,
          "format": "int64",
          "type": "integer"
        },
        "memory_root": {
          "type": [
            "string",
            "null"
          ]
        },
        "model": {
          "type": [
            "string",
            "null"
          ]
        },
        "phase1_concurrency": {
          "default": 2,
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "phase1_idle_seconds": {
          "default": 300,
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "phase1_lease_seconds": {
          "default": 900,
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "phase1_max_age_days": {
          "default": 30,
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "phase1_retry_seconds": {
          "default": 3600,
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "phase1_scan_limit": {
          "default": 8,
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "phase2_lease_seconds": {
          "default": 1800,
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "phase2_limit": {
          "default": 64,
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        }
      },
      "type": "object"
    },
    "AgentSettingsConfig": {
      "description": "Agent-specific settings.",
      "properties": {
        "debug": {
          "default": true,
          "type": "boolean"
        },
        "hooks": {
          "$ref": "#/$defs/AgentHooksConfig",
          "default": {
            "enabled": false
          }
        },
        "memories": {
          "$ref": "#/$defs/AgentMemoriesConfig",
          "default": {
            "enabled": false,
            "extension_retention_days": 30,
            "max_unused_days": 180,
            "phase1_concurrency": 2,
            "phase1_idle_seconds": 300,
            "phase1_lease_seconds": 900,
            "phase1_max_age_days": 30,
            "phase1_retry_seconds": 3600,
            "phase1_scan_limit": 8,
            "phase2_lease_seconds": 1800,
            "phase2_limit": 64
          }
        },
        "tools": {
          "$ref": "#/$defs/AgentToolsConfig",
          "default": {
            "mcp": {
              "enabled": false
            },
            "websearch": {
              "default_provider": "duckduckgo",
              "providers": {
                "arxiv": {},
                "brave": {
                  "auth": {}
                },
                "duckduckgo": {},
                "exa": {
                  "auth": {}
                },
                "google": {
                  "auth": {}
                },
                "searxng": {},
                "serpapi": {
                  "auth": {}
                },
                "tavily": {
                  "auth": {}
                }
              }
            }
          }
        }
      },
      "type": "object"
    },
    "AgentToolsConfig": {
      "description": "Agent tool settings.",
      "properties": {
        "mcp": {
          "$ref": "#/$defs/AgentMcpConfig",
          "default": {
            "enabled": false
          }
        },
        "websearch": {
          "$ref": "#/$defs/AgentWebSearchConfig",
          "default": {
            "default_provider": "duckduckgo",
            "providers": {
              "arxiv": {},
              "brave": {
                "auth": {}
              },
              "duckduckgo": {},
              "exa": {
                "auth": {}
              },
              "google": {
                "auth": {}
              },
              "searxng": {},
              "serpapi": {
                "auth": {}
              },
              "tavily": {
                "auth": {}
              }
            }
          }
        }
      },
      "type": "object"
    },
    "AgentWebSearchConfig": {
      "description": "Agent web search tool configuration.",
      "properties": {
        "default_provider": {
          "$ref": "#/$defs/WebSearchProviderId",
          "default": "duckduckgo"
        },
        "providers": {
          "$ref": "#/$defs/WebSearchProvidersConfig",
          "default": {
            "arxiv": {},
            "brave": {
              "auth": {}
            },
            "duckduckgo": {},
            "exa": {
              "auth": {}
            },
            "google": {
              "auth": {}
            },
            "searxng": {},
            "serpapi": {
              "auth": {}
            },
            "tavily": {
              "auth": {}
            }
          }
        }
      },
      "type": "object"
    },
    "AutoUnloadConfig": {
      "description": "Automatic model-unload settings.",
      "properties": {
        "enabled": {
          "default": false,
          "description": "Whether idle models should be unloaded automatically.",
          "type": "boolean"
        },
        "idle_minutes": {
          "default": 10,
          "description": "Idle timeout before unloading a model.",
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "max_pressure_evictions_per_load": {
          "default": 3,
          "description": "Maximum number of idle-model evictions attempted for a single model load.",
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "min_free_gpu_memory_bytes": {
          "default": 536870912,
          "description": "Minimum free GPU memory required before model loads can proceed without eviction.",
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "min_free_system_memory_bytes": {
          "default": 1073741824,
          "description": "Minimum free system memory required before model loads can proceed without eviction.",
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "type": "object"
    },
    "CapacityConfig": {
      "description": "Shared queue and concurrency limits.",
      "properties": {
        "concurrent_requests": {
          "default": 4,
          "description": "Maximum in-flight requests for the target node.",
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "queue": {
          "default": 64,
          "description": "Submission queue size.",
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        }
      },
      "type": "object"
    },
    "CapacityOverrideConfig": {
      "description": "Capacity overrides applied on top of inherited defaults.",
      "properties": {
        "concurrent_requests": {
          "description": "Override maximum in-flight requests.",
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "queue": {
          "description": "Override submission queue size.",
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "CorsConfig": {
      "description": "Server CORS settings.",
      "properties": {
        "allowed_origins": {
          "description": "Allowed browser origins.",
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "DatabaseConfig": {
      "description": "Shared database configuration.",
      "properties": {
        "url": {
          "description": "Database connection string.",
          "type": "string"
        }
      },
      "required": [
        "url"
      ],
      "type": "object"
    },
    "EndpointConfig": {
      "description": "HTTP and IPC endpoint configuration.",
      "properties": {
        "http": {
          "$ref": "#/$defs/HttpEndpointConfig",
          "default": {}
        },
        "ipc": {
          "$ref": "#/$defs/IpcEndpointConfig",
          "default": {}
        }
      },
      "type": "object"
    },
    "FfmpegToolConfig": {
      "description": "FFmpeg dependency configuration.",
      "properties": {
        "auto_download": {
          "default": true,
          "description": "Whether FFmpeg should be auto-downloaded when missing.",
          "type": "boolean"
        },
        "enabled": {
          "default": true,
          "description": "Whether FFmpeg integration is enabled.",
          "type": "boolean"
        },
        "install_dir": {
          "description": "Installation directory for the ffmpeg sidecar.",
          "type": [
            "string",
            "null"
          ]
        },
        "source": {
          "$ref": "#/$defs/SourceConfig",
          "default": {}
        }
      },
      "type": "object"
    },
    "GeneralSettingsConfig": {
      "description": "General desktop-app settings.",
      "properties": {
        "language": {
          "$ref": "#/$defs/InterfaceLanguagePreference",
          "default": "auto",
          "description": "Preferred desktop interface language."
        }
      },
      "type": "object"
    },
    "GgmlRuntimeBackendsConfig": {
      "description": "GGML leaf backend configuration.",
      "properties": {
        "diffusion": {
          "$ref": "#/$defs/RuntimeLeafConfig",
          "default": {
            "capacity": {},
            "enabled": true,
            "endpoint": {
              "http": {},
              "ipc": {}
            },
            "flash_attn": true,
            "logging": {},
            "source": {}
          }
        },
        "llama": {
          "$ref": "#/$defs/LlamaRuntimeLeafConfig",
          "default": {
            "capacity": {},
            "context_length": 2048,
            "enabled": true,
            "endpoint": {
              "http": {},
              "ipc": {}
            },
            "flash_attn": true,
            "logging": {},
            "source": {}
          }
        },
        "whisper": {
          "$ref": "#/$defs/RuntimeLeafConfig",
          "default": {
            "capacity": {},
            "enabled": true,
            "endpoint": {
              "http": {},
              "ipc": {}
            },
            "flash_attn": true,
            "logging": {},
            "source": {}
          }
        }
      },
      "type": "object"
    },
    "GgmlRuntimeFamilyConfig": {
      "description": "GGML runtime family configuration.",
      "properties": {
        "backends": {
          "$ref": "#/$defs/GgmlRuntimeBackendsConfig",
          "default": {
            "diffusion": {
              "capacity": {},
              "enabled": true,
              "endpoint": {
                "http": {},
                "ipc": {}
              },
              "flash_attn": true,
              "logging": {},
              "source": {}
            },
            "llama": {
              "capacity": {},
              "context_length": 2048,
              "enabled": true,
              "endpoint": {
                "http": {},
                "ipc": {}
              },
              "flash_attn": true,
              "logging": {},
              "source": {}
            },
            "whisper": {
              "capacity": {},
              "enabled": true,
              "endpoint": {
                "http": {},
                "ipc": {}
              },
              "flash_attn": true,
              "logging": {},
              "source": {}
            }
          }
        },
        "capacity": {
          "$ref": "#/$defs/CapacityOverrideConfig",
          "default": {}
        },
        "endpoint": {
          "$ref": "#/$defs/EndpointConfig",
          "default": {
            "http": {},
            "ipc": {}
          }
        },
        "install_dir": {
          "description": "Shared install directory for GGML runtime libraries.",
          "type": [
            "string",
            "null"
          ]
        },
        "logging": {
          "$ref": "#/$defs/LoggingOverrideConfig",
          "default": {}
        },
        "source": {
          "$ref": "#/$defs/SourceConfig",
          "default": {}
        }
      },
      "type": "object"
    },
    "HttpEndpointConfig": {
      "description": "HTTP endpoint configuration.",
      "properties": {
        "address": {
          "description": "Bind or target address used for HTTP/gRPC transport.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "InterfaceLanguagePreference": {
      "description": "Frontend interface language preference stored in settings.json.",
      "enum": [
        "auto",
        "en-US",
        "zh-CN"
      ],
      "type": "string"
    },
    "IpcEndpointConfig": {
      "description": "IPC endpoint configuration.",
      "properties": {
        "path": {
          "description": "IPC socket or named-pipe path.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "LlamaRuntimeLeafConfig": {
      "description": "Llama leaf config with llama-specific controls.",
      "properties": {
        "capacity": {
          "$ref": "#/$defs/CapacityOverrideConfig",
          "default": {}
        },
        "context_length": {
          "description": "Optional context length override.",
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "enabled": {
          "default": true,
          "description": "Whether the llama backend is enabled.",
          "type": "boolean"
        },
        "endpoint": {
          "$ref": "#/$defs/EndpointConfig",
          "default": {
            "http": {},
            "ipc": {}
          }
        },
        "flash_attn": {
          "default": true,
          "description": "Whether Flash Attention is enabled for llama contexts.",
          "type": "boolean"
        },
        "logging": {
          "$ref": "#/$defs/LoggingOverrideConfig",
          "default": {}
        },
        "source": {
          "$ref": "#/$defs/SourceConfig",
          "default": {}
        }
      },
      "type": "object"
    },
    "LoggingConfig": {
      "description": "Shared logging configuration.",
      "properties": {
        "json": {
          "default": false,
          "description": "Emit newline-delimited JSON logs.",
          "type": "boolean"
        },
        "level": {
          "default": "info",
          "description": "Tracing filter or log level.",
          "type": "string"
        },
        "path": {
          "description": "Optional log directory path.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "LoggingOverrideConfig": {
      "description": "Logging overrides applied on top of inherited defaults.",
      "properties": {
        "json": {
          "description": "Override JSON logging mode.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "level": {
          "description": "Override tracing filter or log level.",
          "type": [
            "string",
            "null"
          ]
        },
        "path": {
          "description": "Override log directory path.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "ModelDownloadSourcePreference": {
      "description": "Preferred remote source used when downloading model artifacts.",
      "enum": [
        "auto",
        "hugging_face",
        "model_scope"
      ],
      "type": "string"
    },
    "ModelSettingsConfig": {
      "description": "Model storage settings.",
      "properties": {
        "auto_unload": {
          "$ref": "#/$defs/AutoUnloadConfig",
          "default": {
            "enabled": false,
            "idle_minutes": 10,
            "max_pressure_evictions_per_load": 3,
            "min_free_gpu_memory_bytes": 536870912,
            "min_free_system_memory_bytes": 1073741824
          }
        },
        "cache_dir": {
          "description": "Directory used for cached model artifacts.",
          "type": [
            "string",
            "null"
          ]
        },
        "config_dir": {
          "description": "Directory containing model configuration documents.",
          "type": [
            "string",
            "null"
          ]
        },
        "download_source": {
          "$ref": "#/$defs/ModelDownloadSourcePreference",
          "default": "auto",
          "description": "Preferred remote source used when downloading model artifacts."
        }
      },
      "type": "object"
    },
    "OtelExporter": {
      "description": "Export target for logs, traces, or metrics.",
      "oneOf": [
        {
          "properties": {
            "type": {
              "const": "none",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "type": "object"
        },
        {
          "properties": {
            "directory": {
              "type": "string"
            },
            "type": {
              "const": "local_file",
              "type": "string"
            }
          },
          "required": [
            "type",
            "directory"
          ],
          "type": "object"
        },
        {
          "properties": {
            "endpoint": {
              "type": "string"
            },
            "headers": {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object"
            },
            "protocol": {
              "$ref": "#/$defs/OtelHttpProtocol",
              "default": "binary"
            },
            "tls": {
              "anyOf": [
                {
                  "$ref": "#/$defs/OtelTlsConfig"
                },
                {
                  "type": "null"
                }
              ]
            },
            "type": {
              "const": "otlp_http",
              "type": "string"
            }
          },
          "required": [
            "type",
            "endpoint"
          ],
          "type": "object"
        }
      ]
    },
    "OtelHttpProtocol": {
      "description": "HTTP encoding used by OTLP/HTTP exporters.",
      "enum": [
        "binary",
        "json"
      ],
      "type": "string"
    },
    "OtelSettings": {
      "description": "Runtime OpenTelemetry settings shared by Slab hosts.",
      "properties": {
        "capture_content": {
          "default": false,
          "type": "boolean"
        },
        "enabled": {
          "default": true,
          "type": "boolean"
        },
        "environment": {
          "default": "dev",
          "type": "string"
        },
        "metrics_exporter": {
          "$ref": "#/$defs/OtelExporter",
          "default": {
            "type": "none"
          }
        },
        "service_name": {
          "default": "slab",
          "type": "string"
        },
        "service_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "span_attributes": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "tracestate": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        }
      },
      "type": "object"
    },
    "OtelTlsConfig": {
      "description": "Optional TLS hints for remote OTLP exporters.",
      "properties": {
        "ca_cert_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "domain_name": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "PluginJsRuntimeTransport": {
      "description": "Runtime transport used for JS plugin sidecar communication.",
      "enum": [
        "stdio",
        "uds"
      ],
      "type": "string"
    },
    "PluginPythonRuntimeTransport": {
      "description": "Runtime transport used for Python plugin sidecar communication.",
      "enum": [
        "stdio",
        "uds"
      ],
      "type": "string"
    },
    "PluginSettingsConfig": {
      "description": "Runtime plugin installation settings.",
      "properties": {
        "install_dir": {
          "description": "Directory containing installed runtime plugin packages. Defaults to the `plugins`\ndirectory under the Slab application home.",
          "type": [
            "string",
            "null"
          ]
        },
        "js_runtime_transport": {
          "$ref": "#/$defs/PluginJsRuntimeTransport",
          "default": "stdio",
          "description": "Transport mode used for JS sidecar communication."
        },
        "python_runtime_transport": {
          "$ref": "#/$defs/PluginPythonRuntimeTransport",
          "default": "stdio",
          "description": "Transport mode used for Python sidecar communication."
        }
      },
      "type": "object"
    },
    "ProviderAuthConfig": {
      "description": "Provider authentication settings.",
      "properties": {
        "api_key": {
          "description": "Literal API key stored in settings.",
          "type": [
            "string",
            "null"
          ]
        },
        "api_key_env": {
          "description": "Environment variable containing the API key.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "ProviderDefaultsConfig": {
      "description": "Provider-level default headers and query parameters.",
      "properties": {
        "headers": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "query": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        }
      },
      "type": "object"
    },
    "ProviderFamily": {
      "description": "Supported provider transport families.",
      "enum": [
        "openai_compatible"
      ],
      "type": "string"
    },
    "ProviderRegistryEntry": {
      "description": "A single global provider entry.",
      "properties": {
        "api_base": {
          "description": "Provider API base URL.",
          "type": "string"
        },
        "auth": {
          "$ref": "#/$defs/ProviderAuthConfig",
          "default": {}
        },
        "defaults": {
          "$ref": "#/$defs/ProviderDefaultsConfig",
          "default": {}
        },
        "display_name": {
          "description": "Human-readable display name.",
          "type": "string"
        },
        "family": {
          "$ref": "#/$defs/ProviderFamily",
          "default": "openai_compatible",
          "description": "Provider family implementation."
        },
        "id": {
          "description": "Stable provider identifier.",
          "type": "string"
        }
      },
      "required": [
        "id",
        "display_name",
        "api_base"
      ],
      "type": "object"
    },
    "ProvidersConfig": {
      "description": "Global provider registry configuration.",
      "properties": {
        "registry": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ProviderRegistryEntry"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "RuntimeLeafConfig": {
      "description": "Shared runtime leaf configuration.",
      "properties": {
        "capacity": {
          "$ref": "#/$defs/CapacityOverrideConfig",
          "default": {}
        },
        "enabled": {
          "default": true,
          "description": "Whether the leaf backend is enabled.",
