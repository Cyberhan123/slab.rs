    {
      "id": "cloud",
      "title": "Cloud Providers",
      "description_md": "Global cloud provider configuration used by cloud model entries.",
      "order": 20,
      "subsections": [
        {
          "id": "providers",
          "title": "Cloud Providers",
          "description_md": "OpenAI-compatible cloud provider configuration stored as JSON.",
          "order": 10,
          "properties": [
            {
              "pmid": "chat.providers",
              "label": "Cloud Providers",
              "description_md": "OpenAI-compatible cloud providers referenced by cloud model entries across the app.",
              "editable": true,
              "search_terms": [
                "chat",
                "cloud",
                "provider",
                "api",
                "openai"
              ],
              "storage_kind": "chat_providers",
              "schema": {
                "type": "array",
                "default_value": [],
                "json_schema": {
                  "$schema": "https://json-schema.org/draft/2020-12/schema",
                  "type": "array",
                  "title": "Cloud Providers",
                  "description": "Configure OpenAI-compatible providers referenced by cloud model entries.",
                  "items": {
                    "type": "object",
                    "title": "Provider",
                    "additionalProperties": false,
                    "required": [
                      "id",
                      "name",
                      "api_base"
                    ],
                    "properties": {
                      "id": {
                        "type": "string",
                        "title": "Provider ID",
                        "description": "Stable internal identifier used to distinguish this provider in settings and logs.",
                        "minLength": 1,
                        "examples": ["openai-main"]
                      },
                      "name": {
                        "type": "string",
                        "title": "Display name",
                        "description": "Friendly label shown anywhere this cloud provider is referenced.",
                        "minLength": 1,
                        "examples": ["OpenAI"]
                      },
                      "api_base": {
                        "type": "string",
                        "title": "API base URL",
                        "description": "Base URL for the provider's OpenAI-compatible API endpoint.",
                        "minLength": 1,
                        "examples": ["https://api.openai.com/v1"]
                      },
