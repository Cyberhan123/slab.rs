{
  "$schema": "https://slab.reorgix.com/manifests/v3/slab-manifest.schema.json",
  "schema_version": 3,
  "deployment": "local",
  "id": "whisper-vad",
  "label": "whisper-vad",
  "family": "whisper",
  "metadata": {
    "author": "openai"
  },
  "capabilities": [
    "audio_vad"
  ],
  "engines": [
    {
      "id": "ggml.whisper",
      "format": "ggml"
    }
  ],
  "sources": [
    {
      "kind": "hugging_face",
      "repo_id": "ggml-org/whisper-vad",
      "files": [
        {
          "id": "model",
          "path": "ggml-silero-v6.2.0.bin"
        }
      ]
    }
  ],
  "variants": [
    {
      "id": "model",
      "label": "whisper-vad",
      "$ref": "ref://variants/model.json"
    }
  ],
  "presets": [
    {
      "id": "default",
      "label": "Default",
      "description": "Default preset for whisper-vad.",
      "$ref": "ref://presets/default.json"
    }
  ],
  "default_preset": "default"
}
