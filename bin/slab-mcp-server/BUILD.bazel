load("//tools/bazel:rust.bzl", "slab_rust_binary", "slab_rust_library")

package(default_visibility = ["//visibility:public"])

slab_rust_library(
    name = "slab-mcp-server-lib",
    crate_name = "slab_mcp_server",
)

slab_rust_binary(
    name = "slab-mcp-server",
    srcs = glob(["src/**/*.rs"], exclude = ["src/lib.rs"]),
    deps = [":slab-mcp-server-lib"],
)
