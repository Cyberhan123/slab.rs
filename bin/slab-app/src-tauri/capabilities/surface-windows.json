{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "surface-windows",
  "description": "Capability for independent a2u surface windows (TC-FE-06 / INFRA-11)",
  "webviews": [
    "a2u-*"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-set-focus",
    "core:window:allow-start-dragging",
    "opener:default",
    "window-state:default"
  ]
}
