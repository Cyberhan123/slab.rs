{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-window",
  "description": "Capability for the main host webview",
  "webviews": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-center",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-set-size",
    "core:window:allow-set-focus",
    "core:window:allow-is-maximized",
    "core:window:allow-start-dragging",
    "core:window:allow-toggle-maximize",
    "opener:default",
    "dialog:default",
    "dialog:allow-open",
    "shell:default",
    "mcp-bridge:default",
    "allow-plugin-list",
    "allow-plugin-mount-view",
    "allow-plugin-update-view-bounds",
    "allow-plugin-unmount-view",
    "allow-plugin-call",
    "allow-plugin-api-request",
    "allow-plugin-pick-file",
    "allow-plugin-set-theme-snapshot",
    "allow-plugin-theme-snapshot",
    "allow-workspace-state",
    "allow-workspace-open",
    "allow-workspace-close",
    "allow-workspace-read-directory",
    "allow-workspace-read-file",
    "allow-workspace-search-files",
    "allow-workspace-search-text",
    "allow-workspace-create-file",
    "allow-workspace-create-directory",
    "allow-workspace-rename-path",
    "allow-workspace-delete-path",
    "allow-workspace-write-file",
    "allow-workspace-git-status",
    "allow-workspace-git-stage",
    "allow-workspace-git-unstage",
    "allow-workspace-git-discard",
    "allow-workspace-git-commit",
    "allow-workspace-git-diff",
    "allow-workspace-console-run",
    "allow-workspace-update-plugin-preference",
    "allow-workspace-terminal-session",
    "window-state:default",
    "decorum:allow-show-snap-overlay",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "args": true,
          "cmd": "",
          "name": "binaries/slab-server",
          "sidecar": true
        }
      ]
    }
  ]
}
