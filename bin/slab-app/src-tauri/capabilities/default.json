{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-window",
  "description": "Capability for the main host webview",
  "webviews": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-center",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-set-size",
    "core:window:allow-set-focus",
    "core:window:allow-is-maximized",
    "core:window:allow-start-dragging",
    "core:window:allow-toggle-maximize",
    "opener:default",
    "dialog:default",
    "dialog:allow-open",
    "shell:default",
    "mcp-bridge:default",
    "allow-greet",
    "allow-get-api-url",
    "allow-check-backend-status",
    "allow-get-system-info",
    "allow-plugin-list",
    "allow-plugin-mount-view",
    "allow-plugin-update-view-bounds",
    "allow-plugin-unmount-view",
    "allow-plugin-call",
    "allow-plugin-api-request",
    "allow-health",
    "allow-transcribe",
    "allow-list-chat-models",
    "allow-chat-completions",
    "allow-chat-completions-stream",
    "allow-completions",
    "allow-list-models",
    "allow-create-model",
    "allow-import-model-config",
    "allow-get-model",
    "allow-update-model",
    "allow-delete-model",
    "allow-load-model",
    "allow-unload-model",
    "allow-switch-model",
    "allow-download-model",
    "allow-list-available-models",
    "allow-list-sessions",
    "allow-create-session",
    "allow-delete-session",
    "allow-list-session-messages",
    "allow-list-tasks",
    "allow-get-task",
    "allow-get-task-result",
    "allow-cancel-task",
    "allow-setup-status",
    "allow-download-ffmpeg",
    "allow-complete-setup",
    "allow-backend-status",
    "allow-list-backends",
    "allow-download-backend-lib",
    "allow-reload-backend-lib",
    "allow-gpu-status",
    "allow-list-settings",
    "allow-get-setting",
    "allow-update-setting",
    "window-state:default",
    "decorum:allow-show-snap-overlay",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "args": true,
          "cmd": "",
          "name": "binaries/slab-runtime",
          "sidecar": true
        }
      ]
    }
  ]
}
