{
    "$schema": "https://schema.tauri.app/config/2",
    "app": {
        "windows": [
            {
                "label": "main",
                "title": "Slab",
                "width": 1024,
                "height": 768,
                "resizable": true,
                "center": true,
                "titleBarStyle": "Overlay",
                "hiddenTitle": false,
                "decorations": false,
                "minHeight": 600,
                "minWidth": 800
            }
        ]
    },
    "bundle": {
        "active": true,
        "macOS": {
            "minimumSystemVersion": "13.0"
        },
        "resources": [
            "resources/libs/**/*"
        ]
    }
}