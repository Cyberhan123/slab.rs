{
  "name": "@slab/desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "postinstall": "bunx husky install",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "test": "vitest",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "test:browser:update": "vitest run --config vitest.browser.config.ts -u",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "bun run lint",
    "*.rs": "cargo fmt -- --check"
  },
