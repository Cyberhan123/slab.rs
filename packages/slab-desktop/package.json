{
  "name": "@slab/desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "postinstall": "bunx husky install",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "test": "vitest",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "test:browser:update": "vitest run --config vitest.browser.config.ts -u",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "bun run lint",
    "*.rs": "cargo fmt -- --check"
  },
  "dependencies": {
    "@slab/api": "workspace:*",
    "@slab/components": "workspace:*",
    "@slab/i18n": "workspace:*",
    "@slab/plugin-sdk": "workspace:*",
    "@ant-design/icons": "^6.1.1",
    "@ant-design/x": "^2.5.0",
    "@ant-design/x-markdown": "^2.5.0",
    "@ant-design/x-sdk": "^2.5.0",
    "antd": "^6.3.6",
    "@tanstack/react-query": "^5.99.2",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "~2.7.0",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-shell": "~2.3.5",
    "@tauri-apps/plugin-window-state": "~2.4.1",
    "antd-style": "^4.1.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12",
    "dayjs": "^1.11.20"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.6.5",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/bun": "1.3.12",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.5.0",
    "cross-spawn": "^7.0.6",
    "jsdom": "^29.1.0",
    "postcss": "^8.5.10",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "browserslist": {
    "production": [
      "safari >= 16",
      "ios_saf >= 16",
      "last 2 Chrome versions",
      "last 2 Edge versions",
      "Firefox ESR"
    ],
    "development": [
      "last 1 safari version",
      "last 1 chrome version"
    ]
  },
  "license": "AGPL-3.0-only"
}
