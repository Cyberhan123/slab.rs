{
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "@slab/components": ["../slab-components/src/index.ts"],
      "@slab/components/*": ["../slab-components/src/*"],
      "@slab/i18n": ["../slab-i18n/src/index.ts"]
    },
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"],
  "references": [
    {
      "path": "./tsconfig.node.json"
    }
  ]
}
