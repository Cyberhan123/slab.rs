{
  "name": "@slab/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "api": "bunx openapi-typescript http://127.0.0.1:3000/api-docs/openapi.json -o src/v1.d.ts",
    "build": "tsc --noEmit",
    "test": "vitest --config vitest.config.ts",
    "test:run": "vitest run --config vitest.config.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./config": "./src/config.ts",
    "./errors": "./src/errors.ts",
    "./models": "./src/models.ts",
    "./permissions": "./src/permissions.ts",
    "./plugin": "./src/plugin.ts",
    "./v1": "./src/v1.d.ts"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0",
    "openapi-react-query": "^0.5.4"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.99.2"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.99.2",
    "@types/bun": "1.3.12",
    "@types/node": "^25.6.0",
    "jsdom": "^29.0.2",
    "openapi-typescript": "^7.13.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.4"
  },
  "license": "AGPL-3.0-only"
}
